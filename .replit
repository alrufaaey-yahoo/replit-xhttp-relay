run = "node index.js"
entrypoint = "index.js"
modules = ["nodejs-20:v8-20230920-bd784b9"]
hidden = [".config", ".git"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "node index.js"]
build = ["sh", "-c", "echo build done"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 3000
externalPort = 80
